@@ -892,6 +892,106 @@ Add the weapon, and flash for the player's view
 extern int PM_TorsoAnimForFrame( gentity_t *ent, int torsoFrame );
 extern float CG_ForceSpeedFOV( void );
 
+/*
+==============
+CG_RemoteAddViewWeapon
+
+co-op dual-load: MVP first-person viewmodel for a serverless remote client.
+
+The normal CG_AddViewWeapon builds the viewmodel from the local player's server
+gentity (cent->gent->client->renderInfo, the ghoul2 skeleton, lowerLumbarBone,
+force-power/saber/muzzle state) — none of which is populated for the local player
+on a remote client, so the host path faults there. This draws the gun using only
+cg.* view state and the networked ps->weapon: gun registered from ps->weapon,
+positioned exactly like the host path (CG_CalculateWeaponPosition + cg_gun_*),
+held at a static animation frame (frame 0). No fire animation, no muzzle flash,
+no barrels' spin, no saber/lightning FX yet — those depend on the missing server
+state and are future work (#45). Cosmetic, first-person only; the host never
+reaches here (guarded by cg_remoteClient at the call site).
+==============
+*/
+static void CG_RemoteAddViewWeapon( playerState_t *ps )
+{
+	refEntity_t	hand;
+	refEntity_t	gun;
+	const weaponInfo_t	*weapon;
+	vec3_t		angles;
+	float		fovOffset, leanOffset;
+	float		cgFov = (cg_fovViewmodel.integer) ? cg_fovViewmodel.integer : cg_fov.integer;
+
+	if ( cgFov < 1 )
+		cgFov = 1;
+	else if ( cgFov > 130 )
+		cgFov = 130;
+
+	// no gun in third person, on intermission, when locked, or when hidden
+	if ( cg.renderingThirdPerson )
+		return;
+	if ( ps->pm_type == PM_INTERMISSION )
+		return;
+	if ( ps->eFlags & EF_LOCKED_TO_WEAPON )
+		return;
+	if ( !cg_drawGun.integer || cg.zoomMode || cg.testGun )
+		return;
+	if ( ps->weapon == WP_NONE )
+		return;
+
+	// drop gun lower at higher fov (mirror of the host path, sans force-speed FOV
+	// which needs g_entities[0]'s server client state)
+	float actualFOV = (cg.overrides.active&CG_OVERRIDE_FOV) ? cg.overrides.fov : cg_fov.value;
+	if ( cg_fovViewmodelAdjust.integer && actualFOV > 80 )
+		fovOffset = -0.1 * ( actualFOV - 80 );
+	else
+		fovOffset = 0;
+
+	if ( ps->leanofs != 0 )
+	{
+		leanOffset = ps->leanofs * 0.25f;
+		fovOffset += fabs((double)ps->leanofs) * -0.1f;
+	}
+	else
+	{
+		leanOffset = 0;
+	}
+
+	CG_RegisterWeapon( ps->weapon );
+	weapon = &cg_weapons[ps->weapon];
+
+	// set up gun position (pure cg.* view state, no gentity)
+	memset( &hand, 0, sizeof(hand) );
+	CG_CalculateWeaponPosition( hand.origin, angles );
+
+	VectorMA( hand.origin, cg_gun_x.value, cg.refdef.viewaxis[0], hand.origin );
+	VectorMA( hand.origin, (cg_gun_y.value+leanOffset), cg.refdef.viewaxis[1], hand.origin );
+	VectorMA( hand.origin, (cg_gun_z.value+fovOffset), cg.refdef.viewaxis[2], hand.origin );
+
+	AnglesToAxis( angles, hand.axis );
+
+	if ( cg_fovViewmodel.integer )
+	{
+		float fracDistFOV = tanf( cg.refdef.fov_x * ( M_PI/180 ) * 0.5f );
+		float fracWeapFOV = ( 1.0f / fracDistFOV ) * tanf( cgFov * ( M_PI/180 ) * 0.5f );
+		VectorScale( hand.axis[0], fracWeapFOV, hand.axis[0] );
+	}
+
+	// MVP: static frame — the host maps the torso ghoul2 anim to a weapon frame,
+	// which needs the local player's skeleton the remote client never builds.
+	hand.frame = hand.oldframe = 0;
+	hand.backlerp = 0.0f;
+
+	// add the weapon model, positioned on the hands model's tag_weapon
+	memset( &gun, 0, sizeof(gun) );
+	gun.hModel = weapon->weaponModel;
+	if ( !gun.hModel )
+		return;
+
+	AnglesToAxis( angles, gun.axis );
+	CG_PositionEntityOnTag( &gun, &hand, weapon->handsModel, "tag_weapon" );
+	gun.renderfx = RF_DEPTHHACK | RF_FIRST_PERSON;
+
+	cgi_R_AddRefEntityToScene( &gun );
+}
+
 void CG_AddViewWeapon( playerState_t *ps )
 {
 	refEntity_t	hand;
@@ -924,10 +1024,15 @@ void CG_AddViewWeapon( playerState_t *ps )
 	// ghoul2 model, lowerLumbarBone, force-power state). On a serverless remote
 	// client that gentity state is not populated for the local player (M3
 	// allocates the client struct but the local player's ghoul2/renderInfo stay
-	// empty). Skip the viewmodel rather than fault; the world still renders. A
-	// snapshot-backed local viewmodel is future work. Gate on cg_remoteClient,
-	// not client-pointer nullness (M3 made it non-null). The host keeps its path.
-	if ( cg_remoteClient || !cent->gent || !cent->gent->client )
+	// empty). The full host path faults; instead the remote client draws a
+	// snapshot-backed MVP viewmodel (gun shown, static frame, no fire anim yet)
+	// built only from cg.* + the networked ps->weapon. See CG_RemoteAddViewWeapon.
+	if ( cg_remoteClient )
+	{
+		CG_RemoteAddViewWeapon( ps );
+		return;
+	}
+	if ( !cent->gent || !cent->gent->client )
 	{
 		return;
 	}
