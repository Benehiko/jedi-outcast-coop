+/*
+================
+R_OverbrightTexel
+
+coop render fidelity: apply the software-overbright brightening to one RGB texel
+while preserving its hue. The classic path bakes the overbright << shift into the
+per-channel gamma table, which clamps each channel at 255 independently: on a
+saturated texel the brightest channel hits the ceiling first while the others keep
+climbing, shifting the colour ratio — bright flesh (red-dominant) reads green when
+red clamps and green does not. Instead, scale all three channels by the same
+s_overbrightScale and, if that would push the brightest channel past 255, scale the
+whole texel down by that brightest channel so it caps at 255 with its exact hue.
+The small brightness the roll-off gives up on saturated texels is the correct
+trade for not painting a colour cast onto skin. p points at an RGBA texel; alpha
+(p[3]) is left untouched.
+================
+*/
+static inline void R_OverbrightTexel( byte *p )
+{
+	float r = p[0] * s_overbrightScale;
+	float g = p[1] * s_overbrightScale;
+	float b = p[2] * s_overbrightScale;
+
+	float m = r;
+	if ( g > m ) m = g;
+	if ( b > m ) m = b;
+
+	if ( m > 255.0f )
+	{
+		const float scale = 255.0f / m;
+		r *= scale;
+		g *= scale;
+		b *= scale;
+	}
+
+	p[0] = (byte)( r + 0.5f );
+	p[1] = (byte)( g + 0.5f );
+	p[2] = (byte)( b + 0.5f );
+}
