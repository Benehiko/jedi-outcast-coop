+/*
+================
+CG_HUDEdgeShift
+
+Widescreen HUD edge anchoring. On a framebuffer wider than 4:3, r_aspectCorrect2D
+pillarboxes the 2D layer, which rides the corner HUD widgets inboard with the
+pillarbox band. Return the number of 640-space virtual pixels to shift each side
+outward so the widgets sit at the true screen edges instead: left widgets by
+-shift, right widgets by +shift. Returns 0 when there is nothing to anchor
+(cg_hudEdgeAnchor off, non-widescreen, or a square/tall display), in which case
+the caller leaves the HUD pillarboxed and never flags the draws wide.
+================
+*/
+float CG_HUDEdgeShift( void )
+{
+	if ( !cg_hudEdgeAnchor.integer )
+	{
+		return 0.0f;
+	}
+	if ( cgs.glconfig.vidHeight <= 0 )
+	{
+		return 0.0f;
+	}
+	const float aspect = (float)cgs.glconfig.vidWidth / (float)cgs.glconfig.vidHeight;
+	const float target = 640.0f / 480.0f;
+	if ( aspect <= target )
+	{
+		return 0.0f;	// square or tall: the 2D layer is not pillarboxed horizontally
+	}
+	// Half of the extra virtual width the full-width ortho exposes on each side.
+	// A widget shifted by this lands exactly at the screen edge under RB_SetGL2D's
+	// wide ortho, whose virtual X runs [-halfExtra, 640+halfExtra].
+	return ( 640.0f * ( aspect / target ) - 640.0f ) * 0.5f;
+}
