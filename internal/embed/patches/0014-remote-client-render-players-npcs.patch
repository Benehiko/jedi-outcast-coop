+		nent->client = (gclient_t *)G_Alloc( sizeof( gclient_t ) );
+		if ( !nent->client )
+		{
+			return;
+		}
+		memset( nent->client, 0, sizeof( gclient_t ) );
+	}
+
+	extern void G_SetG2PlayerModel( gentity_t * const ent, const char *modelName,
