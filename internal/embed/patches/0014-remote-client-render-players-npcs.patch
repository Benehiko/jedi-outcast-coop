diff --git a/codeJK2/game/g_main.cpp b/codeJK2/game/g_main.cpp
index db052304..ab580dd0 100644
--- a/codeJK2/game/g_main.cpp
+++ b/codeJK2/game/g_main.cpp
@@ -860,6 +860,30 @@ extern "C" Q_EXPORT void QDECL GetCGameAPI( game_import_t *import ) {
 	// g_debugalloc cvar that G_InitMemory registers.
 	G_InitMemory();
 	IT_LoadItemParms();
+
+	// M3 (remote-client rendering): the dual-loaded cgame renders other players
+	// and NPCs out of g_entities[]/level.clients, which InitGame allocates on the
+	// host. A serverless remote client never runs InitGame, so g_entities[i].client
+	// is null and CG_Player/CG_NewClientinfo early-return, leaving characters
+	// unrendered. When the engine flags us as the remote client, allocate and wire
+	// the client array here, mirroring InitGame's block (client-safe: zeroed
+	// g_entities + one G_Alloc + memset, no server state). The remote client fills
+	// these per-entity from the network in CG_NewClientinfo (players) and the NPC
+	// model path. cg_remoteClient is set by CL_InitCGame's dual-load branch; it is
+	// 0 on the host, so this block is a no-op there and the host keeps its real,
+	// InitGame-allocated clients.
+	if ( gi.cvar( "cg_remoteClient", "0", 0 )->integer )
+	{
+		memset( g_entities, 0, MAX_GENTITIES * sizeof(g_entities[0]) );
+		globals.gentities = g_entities;
+		level.maxclients = MAX_CLIENTS;
+		level.clients = (gclient_t *) G_Alloc( level.maxclients * sizeof(level.clients[0]) );
+		memset( level.clients, 0, level.maxclients * sizeof(level.clients[0]) );
+		for ( int i = 0; i < level.maxclients; i++ )
+		{
+			g_entities[i].client = level.clients + i;
+		}
+	}
 }
 
