+	// The glm path was registered at spawn via G_ModelIndex and rides in
+	// s.modelindex; resolve it back to the configstring path.
+	const int modelIndex = cent->currentState.modelindex;
+	if ( modelIndex <= 0 )
+	{
+		return;		// not a ghoul2-model NPC (or model not networked)
+	}
+	const char *glmPath = CG_ConfigString( CS_MODELS + modelIndex );
+	if ( !glmPath || !glmPath[0] )
+	{
+		return;
+	}
+
+	// Extract "<name>" from "models/players/<name>/model.glm".
+	char modelName[MAX_QPATH] = {0};
+	const char *p = strstr( glmPath, "models/players/" );
+	if ( p )
+	{
+		p += strlen( "models/players/" );
+		const char *slash = strchr( p, '/' );
+		if ( slash && (size_t)(slash - p) < sizeof( modelName ) )
+		{
+			Q_strncpyz( modelName, p, (slash - p) + 1 );
+		}
+	}
+	if ( !modelName[0] )
