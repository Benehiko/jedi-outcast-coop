diff --git a/code/rd-vanilla/tr_backend.cpp b/code/rd-vanilla/tr_backend.cpp
index 741bb95b..81234711 100644
--- a/code/rd-vanilla/tr_backend.cpp
+++ b/code/rd-vanilla/tr_backend.cpp
@@ -975,9 +975,36 @@ RB_SetGL2D
 void	RB_SetGL2D (void) {
 	backEnd.projection2D = qtrue;
 
+	// The 2D HUD and menus are authored in a fixed 640x480 (4:3) virtual space.
+	// Stretching that across a wider framebuffer distorts every element, which
+	// is very visible on 16:9 and severe on 21:9 ultrawide. Instead, map the
+	// 640x480 virtual space to a centred 4:3 region of the framebuffer and leave
+	// the extra width as black pillarbox bars, so 2D art keeps its intended
+	// shape. The 3D world view still fills the screen (its FOV is widened
+	// separately by cg_fovAspectAdjust). r_aspectCorrect2D disables this to
+	// restore the legacy full-width stretch.
+	int x = 0, y = 0, w = glConfig.vidWidth, h = glConfig.vidHeight;
+	if ( r_aspectCorrect2D && r_aspectCorrect2D->integer && glConfig.vidHeight > 0 )
+	{
+		const float aspect = (float)glConfig.vidWidth / (float)glConfig.vidHeight;
+		const float target = 640.0f / 480.0f;
+		if ( aspect > target )
+		{
+			// too wide: pillarbox (bars left and right)
+			w = (int)( glConfig.vidHeight * target + 0.5f );
+			x = ( glConfig.vidWidth - w ) / 2;
+		}
+		else if ( aspect < target )
+		{
+			// too tall: letterbox (bars top and bottom)
+			h = (int)( glConfig.vidWidth / target + 0.5f );
+			y = ( glConfig.vidHeight - h ) / 2;
+		}
+	}
+
 	// set 2D virtual screen size
-	qglViewport( 0, 0, glConfig.vidWidth, glConfig.vidHeight );
-	qglScissor( 0, 0, glConfig.vidWidth, glConfig.vidHeight );
+	qglViewport( x, y, w, h );
+	qglScissor( x, y, w, h );
 	qglMatrixMode(GL_PROJECTION);
     qglLoadIdentity ();
 	qglOrtho (0, 640, 480, 0, 0, 1);
