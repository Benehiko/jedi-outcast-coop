diff --git a/codeJK2/game/wp_blaster_rifle.cpp b/codeJK2/game/wp_blaster_rifle.cpp
index 90aa75e3..d8a4ea1b 100644
--- a/codeJK2/game/wp_blaster_rifle.cpp
+++ b/codeJK2/game/wp_blaster_rifle.cpp
@@ -39,6 +39,16 @@ static void WP_FireBlasterMissile( gentity_t *ent, vec3_t start, vec3_t dir, qbo
 	int velocity	= g_blasterVelocity ? g_blasterVelocity->integer : BLASTER_VELOCITY;
 	int	damage		= !altFire ? weaponData[WP_BLASTER].damage : weaponData[WP_BLASTER].altDamage;
 
+	// Modern combat: let the player's E-11 primary hit harder than the stock
+	// 20/bolt (which reads as "weak") without touching NPC balance or the
+	// data-driven .wpn value. g_blasterDamage 0 = use the loaded weaponData
+	// damage (retail); >0 overrides it for player-fired bolts only.
+	const qboolean playerFired = ( ent && ent->s.number == 0 ) ? qtrue : qfalse;
+	if ( playerFired && !altFire && g_blasterDamage && g_blasterDamage->integer > 0 )
+	{
+		damage = g_blasterDamage->integer;
+	}
+
 	// If an enemy is shooting at us, lower the velocity so you have a chance to evade
 	if ( ent->client && ent->client->ps.clientNum != 0 )
 	{
@@ -87,7 +97,20 @@ static void WP_FireBlasterMissile( gentity_t *ent, vec3_t start, vec3_t dir, qbo
 //	}
 
 	missile->damage = damage;
-	missile->dflags = DAMAGE_DEATH_KNOCKBACK;
+	// Stock blaster bolts carry DAMAGE_DEATH_KNOCKBACK, so a hit only shoves the
+	// target when it *kills* — a living enemy takes zero push, which is why
+	// connecting shots feel like they do nothing. For the player's primary fire,
+	// g_blasterKnockback 1 (default) drops the death-only flag so every hit runs
+	// the normal live-target knockback path (a small, mass-scaled shove). Set 0
+	// to restore stock behavior (knockback on death only).
+	if ( playerFired && !altFire && g_blasterKnockback && g_blasterKnockback->integer )
+	{
+		missile->dflags = 0;
+	}
+	else
+	{
+		missile->dflags = DAMAGE_DEATH_KNOCKBACK;
+	}
 	if ( altFire )
 	{
 		missile->methodOfDeath = MOD_BLASTER_ALT;
@@ -129,9 +152,17 @@ void WP_FireBlaster( gentity_t *ent, qboolean alt_fire )
 		}
 		else
 		{
-			// add some slop to the main-fire direction
-			angs[PITCH] += Q_flrand(-1.0f, 1.0f) * BLASTER_MAIN_SPREAD;
-			angs[YAW]	+= Q_flrand(-1.0f, 1.0f) * BLASTER_MAIN_SPREAD;
+			// Player primary fire. Stock JK2 sprays every bolt within a random
+			// +/-BLASTER_MAIN_SPREAD (0.5deg) cone, so shots wander off the
+			// fixed center crosshair and the gun feels inaccurate. g_blasterSpread
+			// is that half-angle in degrees; default 0 = pinpoint (bolt goes
+			// exactly where you aim). Set it to 0.5 to restore the retail spray.
+			const float spread = g_blasterSpread ? g_blasterSpread->value : BLASTER_MAIN_SPREAD;
+			if ( spread > 0.0f )
+			{
+				angs[PITCH] += Q_flrand(-1.0f, 1.0f) * spread;
+				angs[YAW]	+= Q_flrand(-1.0f, 1.0f) * spread;
+			}
 		}
 	}
 
