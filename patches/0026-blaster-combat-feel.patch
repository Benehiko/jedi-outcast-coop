 qboolean	stop_icarus = qfalse;
 
@@ -592,6 +595,9 @@ void G_InitCvars( void ) {
 	g_saberAnimSpeed = gi.cvar( "g_saberAnimSpeed", "1", CVAR_ARCHIVE|CVAR_CHEAT );//how fast saber animations run
