+the caller leaves the HUD pillarboxed and never flags the draws wide.
+================
+*/
+float CG_HUDEdgeShift( void )
+{
+	if ( !cg_hudEdgeAnchor.integer )
+	{
+		return 0.0f;
+	}
+	if ( cgs.glconfig.vidHeight <= 0 )
+	{
+		return 0.0f;
+	}
+	const float aspect = (float)cgs.glconfig.vidWidth / (float)cgs.glconfig.vidHeight;
+	const float target = 640.0f / 480.0f;
+	if ( aspect <= target )
+	{
+		return 0.0f;	// square or tall: the 2D layer is not pillarboxed horizontally
